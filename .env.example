# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── GitHub (required for component generation, variant generation, and scan) ──
# Personal Access Token with repo + workflow scopes
VITE_GITHUB_TOKEN=ghp_...
# Your GitHub username or org
VITE_GITHUB_OWNER=your-username
# The component-library repo name
VITE_GITHUB_REPO=component-library

# ── Anthropic (optional – only needed if you want in-browser fallback) ────────
# The main Claude calls happen in GitHub Actions via ANTHROPIC_API_KEY (GitHub Secret).
# You don't need this for normal use.
VITE_ANTHROPIC_API_KEY=sk-ant-...
